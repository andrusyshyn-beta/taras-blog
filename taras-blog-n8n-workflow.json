    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst filtered = items.filter(item => {\n  const text = ((item.json.title || '') + ' ' + (item.json.content || '')).toLowerCase();\n  return text.includes('ai') || text.includes('agent') || text.includes('autonomous') || text.includes('intelligence');\n});\nconst deduped = Array.from(new Set(filtered.map(a => a.json.title)))\n  .map(title => filtered.find(a => a.json.title === title).json);\n\nreturn { headlines: deduped.slice(0, 8).map(i => `[${i.title}] (Snippet: ${(i.contentSnippet || i.content || 'N/A').substring(0, 500)}...)`).join('\\n\\n') };"
      },
      "id": "1c2d3e4f-5a6b-7c8d-9e0f-1a2b3c4d5e6f",
      "name": "Aggregate_News",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        50,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const news = $node[\"Aggregate_News\"].json.headlines;\nreturn {\n  payload: {\n    model: \"llama-3.3-70b-versatile\",\n    response_format: { type: \"json_object\" },\n    messages: [\n      { role: \"system\", content: \"Виберіть одну тему. Поверніть JSON: {topic, summary, reason, slug}\" },\n      { role: \"user\", content: \"Новини: \\n\" + news }\n    ]\n  }\n};"
      },
