    {
      "parameters": {
        "jsCode": "const resp = JSON.parse($json.choices[0].message.content);\nconst selectionData = JSON.parse($node[\"Groq_Select_Top_Topic\"].json.choices[0].message.content);\nconst slug = selectionData.slug;\n\nconst now = new Date().toISOString().split('T')[0];\nconst clean = (txt) => txt.replace(/^[ \t]+/gm, '').trim();\nconst createMD = (d) => `--- \\ntitle: \"${d.title}\"\\ndate: \"${now}\"\\nupdated: \"${now}\"\\nexcerpt: \"${d.excerpt}\"\\ncategory: \"${d.category}\"\\ntags: ${JSON.stringify(d.tags)}\\nfeatured: false\\nimage: \"\"\\n---\\n\\n${clean(d.content)}`;\n\nreturn {\n  ua: { path: `content/posts/${slug}.md`, content: createMD(resp.ua) },\n  en: { path: `content/posts/en/${slug}.md`, content: createMD(resp.en) },\n  topic: resp.ua.title\n};"
      },
